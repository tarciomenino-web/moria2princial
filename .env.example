# Copie este arquivo para .env e preencha com os dados do seu projeto Supabase.
# (o Prisma e o Next leem o .env; o .env fica fora do git)
# Onde achar: painel do Supabase -> botão "Connect" (topo da página) -> aba ORMs / Prisma.

# Conexão do app rodando (Transaction pooler, porta 6543).
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-1-SUA_REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta, usada só pelas migrations do Prisma (Session pooler, porta 5432).
DIRECT_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-1-SUA_REGIAO.pooler.supabase.com:5432/postgres"

# Segredo que assina o cookie de login. Gere um novo com:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="troque-por-uma-string-aleatoria-longa"

# Chave service_role da API REST. O Prisma não usa (ele fala direto com o Postgres).
# Ignora RLS: só no servidor, nunca com prefixo NEXT_PUBLIC_.
# SUPABASE_SECRET_KEY="sb_secret_..."

# Chaves públicas do Supabase — só serão necessárias quando usarmos Storage/Realtime.
# NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
